# Bitbucket App Password for API access
# Create one at: https://bitbucket.org/account/settings/app-passwords/
# Required permissions: Repositories (Read)
BITBUCKET_USERNAME=your_bitbucket_username
BITBUCKET_APP_PASSWORD=your_app_password
BITBUCKET_WORKSPACE=gmeremittance

# Optional: protect the cron endpoint
CRON_SECRET=your_secret_here
